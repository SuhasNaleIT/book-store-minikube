# ─────────────────────────────────────────────────────────────
# app-service/.env.example
# Safe to commit — shows teammates what variables are needed.
# HOW TO USE:
#   cp .env.example .env
#   Fill in your actual values in .env
#   NEVER commit the actual .env file
# ─────────────────────────────────────────────────────────────

FLASK_ENV=development

# Flask secret key — only needed for Flask internals
# catalogue-service has no sessions or forms but Flask requires it
SECRET_KEY=your-secret-key-here

# catalogue-service PostgreSQL — separate DB from app-service
DATABASE_URL=postgresql://bookstore_user:bookstore_pass@localhost:5432/app_db
