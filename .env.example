# ─────────────────────────────────────────────────────────────
# .env.example
# This file is safe to commit to GitHub.
# It shows teammates what environment variables are needed.
#
# HOW TO USE:
#   cp .env.example .env
#   Then fill in your actual values in .env
#   NEVER commit the actual .env file
# ─────────────────────────────────────────────────────────────

FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://bookstore_user:bookstore_pass@localhost:5432/bookstore_db
