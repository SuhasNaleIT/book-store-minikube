SECRET_KEY=rendomsecretkey
# Flask uses this to:
# - sign browser cookies (login sessions)
# - protect forms against CSRF attacks
# - NEVER share this publicly or commit to Git
# You can type any random string here

DATABASE_URL=postgresql://flask_user:flask_pass@localhost:5432/flask_demo_db
# tells Flask where PostgreSQL is
# format: postgresql://username:password@host:port/database_name
# bookuser    → PostgreSQL username (we set this when starting Docker)
# bookpass    → PostgreSQL password
# localhost   → running on your Mac
# 5432        → default PostgreSQL port
# bookstore   → database name

FLASK_APP=run.py
# tells Flask which file is the entry point

FLASK_ENV=development
# enables debug mode, auto-reload on code changes
